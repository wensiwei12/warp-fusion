rule weak_password_check {
    events { e : conn_events }
    on each e where external("password_check", e.chars) -> score(45.0)
    entity(ip, e.sip)
    yield bot_alerts (
        sip = e.sip,
        alert_type = "weak_password",
        detail = fmt("external() lookup on {}", e.chars),
        request_count = 1
    )
    limits { max_memory = "64MB"; max_instances = 10000; on_exceed = throttle; }
}
