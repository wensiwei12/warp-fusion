// ---------------------------------------------------------------------------
// wfusion domain — flows
// Crate: wfusion
// ---------------------------------------------------------------------------

// Dispatch：CLI 入口 — 解析子命令，分发到对应域
flow Dispatch {
  actor User
  trigger Dispatch
  creates DispatchResult

  step ParseSubcommand {
    create DispatchResult {
      subcommand = Dispatch.subcommand
      domain = Dispatch.subcommand
    }
  }
}
